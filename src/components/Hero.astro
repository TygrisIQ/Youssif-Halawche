---
import SkillCard from "./elements/SkillCard.astro"
---

<section id="hero">
  <div class="hero">
    <div class="hi"> Hi, my name is</div>
    <h2>YOUSSIF AL-HALAWCHE</h2>
    <p class="typewriter">
      <span id="tw"></span><span class="cursor">|</span>
    </p>
    <SkillCard name="Rust"   color="#f74c00"  />
  </div>
</section>










<script is:inline>
const phrases = [
  "I focus on correctness first.",
  "I build with intent.",
  "I write code that scales",
  "I build reliable systems.",
  "I design highly scalable database schemas.",
  "I make things render fast.",
  "I architect secure-by-design platforms..",
  "I think latency is a bug.",

];

let phraseIndex = 0;
let charIndex = 0;
let deleting = false;
const el = document.getElementById("tw");

const prefix = "I ";

function tick() {
  const current = phrases[phraseIndex];

  if (!deleting) {
    charIndex++;
    el.textContent = current.slice(0, charIndex);
    if (charIndex === current.length) {
      deleting = true;
      setTimeout(tick, 1800);
      return;
    }
  } else {
    charIndex--;
    el.textContent = current.slice(0, charIndex);
    if (charIndex === prefix.length) {
      deleting = false;
      let next;
      do { next = Math.floor(Math.random() * phrases.length); } while (next === phraseIndex);
      phraseIndex = next;
      charIndex = prefix.length;
    }
  }

  setTimeout(tick, deleting ? 10 : 30);
}

charIndex = prefix.length;
tick();
</script>

<style>
  .hi{
    color: chocolate;
  }
section {
  min-height: 100vh;
  display: flex;
  align-items: center;
}
.hero {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.hero h2 {
  font-size: 3.5rem;
  font-weight: bold;
  color: #ffffff;
  margin: 0;
}
.hero p {
  font-size: 1.2rem;
  color: rgba(255,255,255,0.5);
  margin: 0;
}
.typewriter {
  color: rgba(255,255,255,0.75) !important;
}
.cursor {
  animation: blink 0.7s infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
</style>