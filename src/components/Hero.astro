---
import StatusBadge from "./elements/StatusBadge.astro"
import TerminalTypewriter from "./elements/TerminalTypewriter.astro"
import HeroCTA from "./elements/HeroCTA.astro"

const phrases = [
  "I design highly scalable database schemas.",
  "I enforce strict clean architecture.",
  "I engineer industrial-grade platforms.",
  "I write memory-safe Rust.",
  "I architect secure-by-design APIs.",
  "I think latency is a bug.",
];
---

<section id="hero">
  <div class="hero-content">
    <StatusBadge text="Available Now" />
    <h1 class="name">
      Youssif<br />
      <span class="last-name">Akkad.</span>
    </h1>
    <TerminalTypewriter phrases={phrases} path="~/portfolio" branch="main" />
    <p class="subtitle">
      Developer experienced in backend development, REST APIs, and Linux-based tooling.
    </p>
    <HeroCTA
      primaryText="View Projects"
      primaryHref="#projects"
      secondaryText="GitHub"
      secondaryHref="https://github.com/TygrisIQ"
      secondaryExternal={true}
      thirdText="Get In Touch"
      thirdHref="#contact"
    />
  </div>
</section>

<style>
section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding-top: 5rem;
  scroll-margin-top: 5rem;
}
.hero-content {
  display: flex;
  flex-direction: column;
  gap: 1.8rem;
  max-width: 800px;
  width: 100%;
}
.name {
  font-size: clamp(2.6rem, 8vw, 5.5rem);
  font-weight: 800;
  color: #f8fafc;
  margin: 0;
  line-height: 1.05;
  letter-spacing: -0.02em;
}
.last-name {
  color: transparent;
  -webkit-text-stroke: 1.5px #94a3b8;
}
.subtitle {
  font-size: 1.05rem;
  color: #64748b;
  max-width: 580px;
  line-height: 1.75;
  margin: 0;
}
@media (max-width: 600px) {
  section { padding-top: 5rem; align-items: flex-start; padding-bottom: 3rem; min-height: 100svh; }
  .hero-content { gap: 1.1rem; }
  .subtitle { font-size: 0.9rem; line-height: 1.7; }
}
</style>