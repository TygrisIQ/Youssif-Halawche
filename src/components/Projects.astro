---
import PageHeader from "./elements/PageHeader.astro"
import ProjectCard from "./elements/ProjectCard.astro"
import eup from "../assets/astro.svg"
---
<section id="projects">
  <PageHeader title="Projects" number="2."/>
  <div class="grid">
    <ProjectCard
      title="Euphrates Engine"
      description="A 3D rendering engine built from scratch in Rust using OpenGL."
      tags={["Rust", "OpenGL", "GLFW"]}
      github="https://github.com/TygrisIQ/euphrates_engine"
      image="/screenshots/eup.webp"
      featured={true}
    />
    <ProjectCard
      title="Playport"
      description="A server-client virtual joystick application built on top of the Uinput linux library."
      tags={["Rust", "Linux", "Uinput", "Kotlin", "Java", "Tcp", "Udp"]}
      github="https://github.com/TygrisIQ/euphrates_engine"
      image="/screenshots/playport.webp"

    />
    <ProjectCard
      title="SecondPulse"
      description="Megahacks 2026 Hackathon community support application"
      tags={["React", "React-Native", "Javascript", "Typescript", "Supabase"]}
      github="https://github.com/TygrisIQ"
    />
  </div>
</section>

<style>
section {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 4rem 0;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}
</style>