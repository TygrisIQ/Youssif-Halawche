---
import PageHeader from "./elements/PageHeader.astro"
import ProjectCard from "./elements/ProjectCard.astro"
---
<section id="projects">
  <PageHeader title="Projects" number="02."/>
  <div class="grid" data-reveal>
    <ProjectCard
      title="Euphrates Engine"
      description="A fully-featured 3D rendering engine built from scratch in Rust. No game engine, no shortcuts — raw OpenGL, custom scene graph, and memory-safe design. A project about understanding the machine."
      tags={["Rust", "OpenGL", "GLFW", "glow"]}
      github="https://github.com/TygrisIQ/euphrates_engine"
      image={`${import.meta.env.BASE_URL}/screenshots/eup.webp`}
      featured={true}
    />
    <ProjectCard
      title="Playport"
      description="A virtual joystick system bridging a Kotlin/Java Android app with a Rust server over TCP/UDP. The server injects analog input directly into the Linux kernel via the Uinput interface — the OS sees it as a real controller."
      tags={["Rust", "Linux", "Uinput", "Kotlin", "Android", "TCP/UDP"]}
      github="https://github.com/TygrisIQ"
      image={`${import.meta.env.BASE_URL}/screenshots/playport.webp`}
    />
    <ProjectCard
      title="SecondPulse"
      description="Built in 36 hours at MegaHacks 2026. A full-stack community support platform with real-time features, running cross-platform as a web app and native mobile app from a shared codebase."
      tags={["React", "React Native", "TypeScript", "Supabase", "PostgreSQL"]}
      github="https://github.com/TygrisIQ"
    />
  </div>
</section>

<style>
section {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 4rem 0;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}
</style>